--Advanced Filtering
SELECT *
FROM Purchases
ORDER BY price DESC
LIMIT 5;

--Using Multiple Tables Separately
SELECT *
FROM songs
WHERE popularity_score > 90;

SELECT *
FROM purchases
WHERE song_id IN (
SELECT song_id
FROM songs
WHERE popularity_score > 90);

--Range Checking
SELECT *
FROM purchases
WHERE purchase_date BETWEEN '2023-01-01' AND '2023-03-31';

