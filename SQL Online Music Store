  --Basic Selection
SELECT  
release_date,
title 
 FROM Songs;

SELECT *
FROM songs
WHERE release_date BETWEEN '2022-01-01' AND '2022-12-31';

--Filtering
SELECT *
FROM songs
WHERE popularity_score > 80
AND duration_seconds < 240;

--Pattern Matching
SELECT *
FROM Artist
WHERE artist_name LIKE 'THE%';

--Multiple Conditions
SELECT *
FROM Customers
WHERE join_date LIKE '2022%';

--Calculations and Aliasing
SELECT SUM(duration_seconds) AS total_length
FROM songs;

